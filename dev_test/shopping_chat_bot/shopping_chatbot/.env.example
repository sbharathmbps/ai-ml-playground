# Copy this to .env and fill in your values

# SQLite (default — zero setup)
# DATABASE_URL=sqlite:///./shopping.db

# PostgreSQL (uncomment to use)
DATABASE_URL=postgresql+psycopg2://ml_playground:ml_playground@123@localhost:5432/ml_platform

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
LLM_TEMPERATURE=0.1
LLM_CTX_WINDOW=4096
LLM_TIMEOUT_SEC=120

DEBUG=false
